# Database (Neon PostgreSQL in production, Docker PostgreSQL locally)
DATABASE_URL="postgresql://inovatic:your_password@localhost:5432/inovatic"

# Auth.js v5
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Uploadthing (file uploads for learning materials)
UPLOADTHING_TOKEN="your-uploadthing-token"

# Resend (transactional email)
RESEND_API_KEY="re_your_api_key_here"

# Email sender (must be a verified domain in Resend)
EMAIL_FROM="Inovatic <noreply@udruga-inovatic.hr>"
