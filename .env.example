# Database (Neon PostgreSQL in production, Docker PostgreSQL locally)
# Production (Neon): use the pooled connection URL for DATABASE_URL, direct URL for DIRECT_URL
# Local: both can point to the same local database
DATABASE_URL="postgresql://inovatic:your_password@localhost:5432/inovatic"
DIRECT_URL="postgresql://inovatic:your_password@localhost:5432/inovatic"

# Auth.js v5
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Uploadthing (file uploads for learning materials - Phase 2)
UPLOADTHING_TOKEN="your-uploadthing-token"

# Cloudinary (article images + media)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend (transactional email)
RESEND_API_KEY="re_your_api_key_here"

# Email sender (must be a verified domain in Resend)
EMAIL_FROM="Inovatic <noreply@udruga-inovatic.hr>"
