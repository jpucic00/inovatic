generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum CourseLevel {
  SLR_1
  SLR_2
  SLR_3
  SLR_4
}

enum InquiryStatus {
  NEW
  SCHEDULE_SENT
  CONFIRMED
  ACCOUNT_CREATED
  DECLINED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MaterialType {
  DOCUMENT
  PRESENTATION
  VIDEO
  LINK
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherAssignments TeacherAssignment[]
  enrollments        Enrollment[]
  articles           Article[]
  materials          Material[]
}

model Course {
  id          String       @id @default(cuid())
  slug        String       @unique
  level       CourseLevel?
  title       String
  subtitle    String?
  description String       @db.Text
  ageMin      Int
  ageMax      Int
  equipment   String?
  price       Float?
  priceYear   Decimal?     @db.Decimal(10, 2)
  priceModule Decimal?     @db.Decimal(10, 2)
  imageUrl    String?
  sortOrder   Int          @default(0)
  isCustom    Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  modules         CourseModule[]
  scheduledGroups ScheduledGroup[]
  inquiries       Inquiry[]
}

model CourseModule {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String? @db.Text
  sortOrder   Int     @default(0)

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]
}

model Location {
  id       String  @id @default(cuid())
  name     String
  address  String
  lat      Float?
  lng      Float?
  phone    String?
  email    String?
  isActive Boolean @default(true)

  scheduledGroups ScheduledGroup[]
}

model ScheduledGroup {
  id              String    @id @default(cuid())
  courseId        String
  locationId      String
  name            String?
  date            String?
  dayOfWeek       String?
  startTime       String?
  endTime         String?
  schoolYear      String?
  maxStudents     Int       @default(12)
  enrollmentStart DateTime?
  enrollmentEnd   DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  course               Course               @relation(fields: [courseId], references: [id])
  location             Location             @relation(fields: [locationId], references: [id])
  teacherAssignments   TeacherAssignment[]
  enrollments          Enrollment[]
  materials            Material[]
  inquiryGroupOptions  InquiryGroupOption[]
  assignedInquiries    Inquiry[]            @relation("AssignedGroup")
  preferredInquiries   Inquiry[]            @relation("PreferredGroup")
}

model TeacherAssignment {
  id               String @id @default(cuid())
  userId           String
  scheduledGroupId String

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduledGroupId])
}

model Inquiry {
  id              String        @id @default(cuid())
  parentName      String
  parentEmail     String
  parentPhone     String
  childFirstName      String
  childLastName       String
  childDateOfBirth    String?
  childSchool         String?
  courseLevelPref CourseLevel?
  locationPref    String?
  courseId        String?
  scheduledGroupId String?
  message         String?       @db.Text
  referralSource  String?
  consentGivenAt  DateTime?
  status          InquiryStatus @default(NEW)
  assignedGroupId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  groupOptions     InquiryGroupOption[]
  course           Course?         @relation(fields: [courseId], references: [id])
  scheduledGroup   ScheduledGroup? @relation("PreferredGroup", fields: [scheduledGroupId], references: [id])
  assignedGroup    ScheduledGroup? @relation("AssignedGroup", fields: [assignedGroupId], references: [id])
}

model InquiryGroupOption {
  id               String @id @default(cuid())
  inquiryId        String
  scheduledGroupId String

  inquiry        Inquiry        @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id])

  @@unique([inquiryId, scheduledGroupId])
}

model Enrollment {
  id               String           @id @default(cuid())
  userId           String
  scheduledGroupId String
  schoolYear       String
  status           EnrollmentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id])

  @@unique([userId, scheduledGroupId, schoolYear])
}

model Material {
  id               String       @id @default(cuid())
  scheduledGroupId String
  moduleId         String?
  title            String
  description      String?      @db.Text
  type             MaterialType
  fileUrl          String?
  fileSize         Int?
  mimeType         String?
  sortOrder        Int          @default(0)
  isPublished      Boolean      @default(false)
  uploadedById     String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id])
  module         CourseModule?  @relation(fields: [moduleId], references: [id])
  uploadedBy     User           @relation(fields: [uploadedById], references: [id])
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  content     Json      @default("[]")
  coverImage  String?
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User          @relation(fields: [authorId], references: [id])
  tags   ArticleTag[]
  images ArticleImage[]
}

model ArticleImage {
  id        String  @id @default(cuid())
  articleId String
  url       String
  caption   String?
  sortOrder Int     @default(0)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}
