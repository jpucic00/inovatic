generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum CourseLevel {
  SLR_1
  SLR_2
  SLR_3
  SLR_4
}

enum InquiryStatus {
  NEW
  SCHEDULE_SENT
  CONFIRMED
  ACCOUNT_CREATED
  DECLINED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MaterialType {
  DOCUMENT
  PRESENTATION
  VIDEO
  LINK
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherAssignments TeacherAssignment[]
  enrollments        Enrollment[]
  articles           Article[]
  materials          Material[]
}

model Course {
  id          String      @id @default(cuid())
  slug        String      @unique
  level       CourseLevel
  title       String
  subtitle    String?
  description String      @db.Text
  ageMin      Int
  ageMax      Int
  equipment   String
  priceYear   Decimal?    @db.Decimal(10, 2)
  priceModule Decimal?    @db.Decimal(10, 2)
  imageUrl    String?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  modules         CourseModule[]
  scheduledGroups ScheduledGroup[]
}

model CourseModule {
  id          String  @id @default(cuid())
  courseId    String
  title       String
  description String? @db.Text
  sortOrder   Int     @default(0)

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials Material[]
}

model Location {
  id       String  @id @default(cuid())
  name     String
  address  String
  lat      Float?
  lng      Float?
  phone    String?
  email    String?
  isActive Boolean @default(true)

  scheduledGroups ScheduledGroup[]
}

model ScheduledGroup {
  id          String   @id @default(cuid())
  courseId    String
  locationId  String
  name        String
  dayOfWeek   Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime   String // "19:00"
  endTime     String // "20:30"
  schoolYear  String // "2025/2026"
  maxCapacity Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course              Course               @relation(fields: [courseId], references: [id])
  location            Location             @relation(fields: [locationId], references: [id])
  teacherAssignments  TeacherAssignment[]
  enrollments         Enrollment[]
  materials           Material[]
  inquiryGroupOptions InquiryGroupOption[]
  inquiries           Inquiry[]            @relation("AssignedGroup")
}

model TeacherAssignment {
  id               String @id @default(cuid())
  userId           String
  scheduledGroupId String

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id], onDelete: Cascade)

  @@unique([userId, scheduledGroupId])
}

model Inquiry {
  id              String        @id @default(cuid())
  parentName      String
  parentEmail     String
  parentPhone     String
  childName       String
  childAge        Int
  childSchool     String?
  courseLevelPref CourseLevel?
  locationPref    String?
  message         String?       @db.Text
  status          InquiryStatus @default(NEW)
  assignedGroupId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  groupOptions  InquiryGroupOption[]
  assignedGroup ScheduledGroup?      @relation("AssignedGroup", fields: [assignedGroupId], references: [id])
}

model InquiryGroupOption {
  id               String @id @default(cuid())
  inquiryId        String
  scheduledGroupId String

  inquiry        Inquiry        @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id])

  @@unique([inquiryId, scheduledGroupId])
}

model Enrollment {
  id               String           @id @default(cuid())
  userId           String
  scheduledGroupId String
  schoolYear       String
  status           EnrollmentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id])

  @@unique([userId, scheduledGroupId, schoolYear])
}

model Material {
  id               String       @id @default(cuid())
  scheduledGroupId String
  moduleId         String?
  title            String
  description      String?      @db.Text
  type             MaterialType
  fileUrl          String?
  fileSize         Int?
  mimeType         String?
  sortOrder        Int          @default(0)
  isPublished      Boolean      @default(false)
  uploadedById     String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  scheduledGroup ScheduledGroup @relation(fields: [scheduledGroupId], references: [id])
  module         CourseModule?  @relation(fields: [moduleId], references: [id])
  uploadedBy     User           @relation(fields: [uploadedById], references: [id])
}

model Article {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  content     String    @db.Text
  coverImage  String?
  authorId    String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User         @relation(fields: [authorId], references: [id])
  tags   ArticleTag[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}
