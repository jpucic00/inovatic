{
  "name": "inovatic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --dir src",
    "lint:ts": "tsc --noEmit",
    "lint:dead": "knip",
    "lint:all": "npm run lint && npm run lint:ts && npm run lint:dead",
    "sonar:start": "docker compose -f docker-compose.sonar.yml up -d",
    "sonar:stop": "docker compose -f docker-compose.sonar.yml down",
    "sonar:scan": "sonar-scanner -Dsonar.host.url=http://localhost:9000 -Dsonar.token=$SONAR_TOKEN",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-images": "tsx scripts/seed-article-images.ts",
    "download-wp-images": "tsx scripts/download-wp-images.ts",
    "migrate-images": "tsx scripts/migrate-images-to-cloudinary.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.1",
    "@blocknote/mantine": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@hookform/resolvers": "^5.2.2",
    "@mantine/core": "^8.3.17",
    "@mantine/hooks": "^8.3.17",
    "@prisma/client": "^6.5.0",
    "@react-email/components": "^0.0.30",
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "next-auth": "^5.0.0-beta.25",
    "next-intl": "^4.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "yet-another-react-lightbox": "^3.29.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.13",
    "knip": "^5.88.0",
    "postcss": "^8.5.0",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
